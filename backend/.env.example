# Database Configuration
DATABASE_NAME=freightflow
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Application Configuration
NODE_ENV=development
PORT=6000
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=<32+ char random string here>
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=<different 32+ char random string here>
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration (Mailtrap for dev)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=<mailtrap username>
MAIL_PASS=<mailtrap password>
MAIL_FROM=noreply@freightflow.io

# File Upload
UPLOAD_DIR=./uploads

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890
REDIS_HOST=localhost  
REDIS_PORT=6379  
